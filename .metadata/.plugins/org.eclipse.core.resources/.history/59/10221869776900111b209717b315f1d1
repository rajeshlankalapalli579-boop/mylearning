

CREATE COMPUTE MODULE flow2222_Compute
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
		CALL CopyMessageHeaders();
		-- CALL CopyEntireMessage();
		SET OutputRoot.XMLNSC.EMP.EMPDETAILS.EMPFULLDETAILS[]=SELECT * FROM InputRoot.XMLNSC.Students.student[] AS S WHERE S.marks=800;
		SET OutputRoot.XMLNSC.EMP.EMPDETAILS.EMPFULL[]=SELECT * FROM InputRoot.XMLNSC. Students.student[] AS S WHERE S.regName='VEERA';
		SET OutputRoot.XMLNSC.EMP.EMPDETAILS.EMPRECORDS[]=select * from AUDIT.STUDENT;
				RETURN TRUE;
	END;

	CREATE PROCEDURE CopyMessageHeaders() BEGIN
		DECLARE I INTEGER 1;
		DECLARE J INTEGER;
		SET J = CARDINALITY(InputRoot.*[]);
		WHILE I < J DO
			SET OutputRoot.*[I] = InputRoot.*[I];
			SET I = I + 1;
		END WHILE;
	END;

	CREATE PROCEDURE CopyEntireMessage() BEGIN
		SET OutputRoot = InputRoot;
	END;
END MODULE;
