

CREATE COMPUTE MODULE messageflow300_Compute
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
		-- CALL CopyMessageHeaders();
		-- CALL CopyEntireMessage();
		FOR S2 AS InputRoot.XMLNSC.employees.employee[] DO
			PASSTHRU('INSERT INTO AUDIT.EMPLOYEE(empno,empname,empadress) VALUES(?,?,?)',s2.empno,s2.empname,s2.empadress);
		END FOR;
			
		RETURN TRUE;
	END;

	CREATE PROCEDURE CopyMessageHeaders() BEGIN
		DECLARE I INTEGER 1;
		DECLARE J INTEGER;
		SET J = CARDINALITY(InputRoot.*[]);
		WHILE I < J DO
			SET OutputRoot.*[I] = InputRoot.*[I];
			SET I = I + 1;
		END WHILE;
	END;

	CREATE PROCEDURE CopyEntireMessage() BEGIN
		SET OutputRoot = InputRoot;
	END;
END MODULE;
